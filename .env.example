# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ========================================
# WHATSAPP / META CONFIGURATION
# ========================================

# WhatsApp API Token from Meta Business Platform
# Get from: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=your_whatsapp_api_token_here

# Phone Number ID (WhatsApp Business Account)
# Get from: Meta Business Platform > WhatsApp > Phone Numbers
PHONE_NUMBER_ID=your_phone_number_id_here

# Facebook Page ID
# Get from: Meta Business Platform > Settings > Pages
FB_PAGE_ID=your_facebook_page_id_here

# Facebook Access Token
# Get from: https://developers.facebook.com/tools/accesstoken/
FB_TOKEN=your_facebook_access_token_here

# WhatsApp Webhook Verification Token (Custom - you create this)
VERIFY_TOKEN=ai_vivek_365

# ========================================
# OPENAI CONFIGURATION
# ========================================

# OpenAI API Key for AI responses
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ========================================
# RENDER WEBHOOK CONFIGURATION
# ========================================

# Render webhook secret for GitHub Actions integration
RENDER_WEBHOOK_SECRET=your_render_webhook_secret

# Render API Key for deployments
RENDER_API_KEY=your_render_api_key

# Render API URL
RENDER_API_URL=https://api.render.com/v1

# ========================================
# GITHUB CONFIGURATION
# ========================================

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_API_TOKEN=ghp_your_github_token_here

# GitHub repository owner
GITHUB_OWNER_NAME=vm6629244-cell

# GitHub repository name
GITHUB_REPO_NAME=Vivek-

# GitHub workflow ID or filename
GITHUB_WORKFLOW_ID=example.yaml

# ========================================
# APPLICATION CONFIGURATION
# ========================================

# Flask app port
PORT=5000

# Environment (development / production)
FLASK_ENV=development

# ========================================
# DATABASE & STORAGE
# ========================================

# Enquiries JSON file path
ENQ_FILE=enquiries.json

# Users JSON file path
USERS_FILE=users.json

# ========================================
# BUSINESS INFORMATION
# ========================================

# UPI ID for payments
UPI_ID=misharvivek0201@axl

# Bot name
BOT_NAME=AI Vivek

# Years of experience (for bot persona)
EXPERIENCE_YEARS=40

# ========================================
# SOCIAL MEDIA HANDLES
# ========================================

INSTAGRAM_HANDLE_1=@vivekmishravoidhissa0007
INSTAGRAM_HANDLE_2=@vivekmishra77771
INSTAGRAM_HANDLE_3=@viv.ek00047
INSTAGRAM_HANDLE_4=@viekvoidhissa0369

# ========================================
# LOGGING
# ========================================

# Log level (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=app.log